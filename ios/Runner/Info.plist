<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>LeHiboo Experiences</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>LeHiboo Experiences</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSCalendarsUsageDescription</key>
	<string>LeHiboo Experiences utilise votre calendrier pour préparer l'ajout de vos réservations à votre agenda.</string>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>LeHiboo Experiences utilise l'accès au calendrier pour ouvrir l'écran d'ajout d'événement avec les détails de votre réservation.</string>
	<key>NSCalendarsWriteOnlyAccessUsageDescription</key>
	<string>LeHiboo Experiences ajoute uniquement vos réservations à votre calendrier lorsque vous le demandez.</string>
	<key>NSCameraUsageDescription</key>
	<string>LeHiboo Experiences utilise la caméra pour scanner les billets à l'entrée des événements.</string>
	<key>NSContactsUsageDescription</key>
	<string>LeHiboo Experiences peut utiliser vos contacts uniquement pour l'autocomplétion de lieu proposée par l'écran calendrier iOS lorsque vous ajoutez une réservation.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>LeHiboo Experiences utilise votre localisation pour vous suggérer des activités proches, lancer une recherche autour de vous et améliorer les réponses de Petit Boo.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>LeHiboo Experiences utilise votre localisation pour vous suggérer des activités proches, lancer une recherche autour de vous et améliorer les réponses de Petit Boo.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>LeHiboo Experiences utilise le microphone uniquement lorsque vous lancez une interaction vocale avec Petit Boo.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>LeHiboo Experiences utilise votre galerie uniquement lorsque vous choisissez une photo de profil.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>LeHiboo Experiences utilise la reconnaissance vocale pour convertir vos demandes vocales à Petit Boo en texte.</string>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>FlutterSceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
